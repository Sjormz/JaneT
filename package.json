{
  "name": "janet",
  "version": "0.2.10",
  "description": "A focused cross-platform terminal workspace with SSH, file browsing, Git tools, and durable sessions",
  "desktopName": "janet",
  "main": "dist/main/index.js",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "postinstall": "node scripts/fix-node-pty-permissions.mjs",
    "dev": "node scripts/dev.mjs",
    "build:main": "node scripts/build-electron.mjs --main",
    "build:preload": "node scripts/build-electron.mjs --preload",
    "build:renderer": "npx vite build --config vite.config.ts",
    "build": "npm run brand:check && npm run build:main && npm run build:preload && npm run build:renderer",
    "brand:generate": "node scripts/generate-brand-assets.mjs",
    "brand:check": "node scripts/generate-brand-assets.mjs --check",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "npm run build && playwright test --config playwright.config.ts",
    "test:e2e:ssh-local": "npm run build && playwright test --config playwright.config.ts tests/e2e/ssh-local.spec.ts",
    "test:watch": "vitest",
    "start": "npx electron dist/main/index.js",
    "dist": "npm run build && npx electron-builder",
    "dist:win": "npm run build && npx electron-builder --win",
    "dist:mac": "npm run build && npx electron-builder --mac",
    "dist:mac:test": "npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false npx electron-builder --mac -c.mac.identity=- -c.mac.hardenedRuntime=false -c.mac.notarize=false -c.npmRebuild=false",
    "dist:linux": "npm run build && npx electron-builder --linux",
    "publish": "npm run build && npx electron-builder --publish always",
    "publish:win": "npm run build && npx electron-builder --win --publish always",
    "publish:mac": "npm run build && npx electron-builder --mac --publish always",
    "publish:linux": "npm run build && npx electron-builder --linux --publish always"
  },
  "build": {
    "appId": "com.sjorm.janet",
    "productName": "JaneT",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release",
      "buildResources": "assets/brand"
    },
    "files": [
      "dist/**/*",
      "assets/runtime/*",
      "assets/licenses/*",
      "!dist/renderer/**/*.map"
    ],
    "asarUnpack": [
      "node_modules/node-pty/**",
      "node_modules/ssh2/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/brand/app-icon.svg",
      "artifactName": "${productName}-Setup-${version}-win-x64.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "JaneT",
      "deleteAppDataOnUninstall": false,
      "displayLanguageSelector": false,
      "unicode": true
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}-win-x64.${ext}",
      "requestExecutionLevel": "user"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/brand/app-icon.svg",
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}",
      "category": "public.app-category.utilities",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "notarize": true,
      "signIgnore": [
        "node_modules/node-pty/prebuilds/darwin-(?:x64|arm64)/(?:pty\\.node|spawn-helper)$"
      ]
    },
    "dmg": {
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/brand/app-icon.svg",
      "artifactName": "${productName}-${version}-linux-x64.${ext}",
      "maintainer": "sjorm <sjorm@users.noreply.github.com>",
      "category": "TerminalEmulator",
      "synopsis": "A focused terminal workspace for local and SSH work",
      "description": "JaneT combines local terminals, SSH, file browsing, Git tools, and durable sessions in one focused workspace",
      "executableName": "janet",
      "syncDesktopName": true
    },
    "publish": {
      "provider": "github",
      "owner": "Sjormz",
      "repo": "JaneT",
      "releaseType": "release"
    }
  },
  "keywords": [
    "terminal",
    "ssh",
    "file-explorer",
    "git"
  ],
  "author": "sjorm <sjorm@users.noreply.github.com>",
  "license": "MIT",
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "electron-updater": "^6.8.9",
    "lucide-react": "^1.23.0",
    "node-pty": "^1.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "simple-git": "^3.36.0",
    "ssh2": "^1.17.0",
    "ssh2-sftp-client": "^12.1.1"
  },
  "devDependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ssh2": "^1.15.0",
    "@types/ssh2-sftp-client": "^9.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.0.0",
    "esbuild": "^0.28.1",
    "jsdom": "^29.1.1",
    "sharp": "^0.35.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  }
}
